{
  "name": "medanalyzer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "render:mermaid": "node ./scripts/render-mermaid.mjs",
    "build-only": "vite build",
    "build:exe": "npm run build-only && node ./scripts/sync-dist-to-deployer.mjs && npx pkg ./deploy-exe/package.json --targets node18-win-x64 --output ./release/MedAnalyzerDeploy.exe",
    "build:macos": "npm run build-only && node ./scripts/sync-dist-to-deployer.mjs && npx -y @yao-pkg/pkg ./deploy-exe/package.json --targets node18-macos-x64 --output ./release/MedAnalyzerDeploy-macos-x64 && npx -y @yao-pkg/pkg ./deploy-exe/package.json --targets node18-macos-arm64 --output ./release/MedAnalyzerDeploy-macos-arm64",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "@vicons/tabler": "^0.13.0",
    "@vicons/utils": "^0.1.4",
    "markdown-it": "^14.1.1",
    "naive-ui": "^2.43.2",
    "pinia": "^3.0.4",
    "three": "^0.165.0",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.10.4",
    "@types/three": "^0.165.0",
    "@vicons/antd": "^0.13.0",
    "@vicons/carbon": "^0.13.0",
    "@vicons/fa": "^0.13.0",
    "@vicons/fluent": "^0.13.0",
    "@vicons/ionicons4": "^0.13.0",
    "@vicons/ionicons5": "^0.13.0",
    "@vicons/material": "^0.13.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitejs/plugin-vue-jsx": "^5.1.3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.2",
    "eslint-plugin-oxlint": "~1.38.0",
    "eslint-plugin-vue": "~10.6.2",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.38.0",
    "prettier": "3.7.4",
    "typescript": "~5.9.3",
    "vfonts": "^0.0.3",
    "vite": "^7.3.0",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vue-tsc": "^3.2.2"
  }
}
